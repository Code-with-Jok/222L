enum RoadmapStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum RoadmapVisibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

model Roadmap {
  id          String  @id @default(uuid())
  title       String
  description String?
  slug        String  @unique

  // status/visibility
  status     RoadmapStatus     @default(DRAFT)
  visibility RoadmapVisibility @default(PUBLIC)

  // owner
  ownerId String @map("owner_id")
  owner   User   @relation("RoadmapOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  // author
  authorId String @map("author_id")
  author   User   @relation("RoadmapAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  // version
  currentVersionId String?          @unique @map("current_version_id")
  currentVersion   RoadmapVersion?  @relation("RoadmapCurrentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  versions         RoadmapVersion[] @relation("RoadmapVersions")

  // timestamps
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // relationships
  nodes             RoadmapNode[]    @relation("RoadmapNodes")
  referencedByNodes RoadmapNode[]    @relation("RoadmapReferences")
  tags              TagsOnRoadmaps[] @relation("RoadmapTags")
  bookmarks         Bookmark[]       @relation("RoadmapBookmarks")
  progressEntries   UserProgress[]   @relation("RoadmapProgress")

  @@map("roadmaps")
}

enum RoadmapVersionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model RoadmapVersion {
  id            String @id @default(uuid())
  roadmapId     String @map("roadmap_id")
  versionNumber Int    @map("version_number")
  changelog     String?
  // content
  snapshotData Json
  title        String
  description  String?
  status       RoadmapVersionStatus @default(DRAFT)

  // creator
  createdById   String    @map("created_by_id")
  publishedById String?   @map("published_by_id")
  publishedAt   DateTime? @map("published_at")

  // timestamps
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // relationships
  roadmap          Roadmap  @relation("RoadmapVersions", fields: [roadmapId], references: [id], onDelete: Cascade)
  activeForRoadmap Roadmap? @relation("RoadmapCurrentVersion")
  createdBy        User     @relation("RoadmapVersionCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  publishedBy      User?    @relation("RoadmapVersionPublishedBy", fields: [publishedById], references: [id], onDelete: Cascade)

  @@unique([roadmapId, versionNumber])
  @@index([roadmapId, versionNumber])
  @@index([status, createdAt])
  @@map("roadmap_versions")
}

enum NodeType {
  PRACTICE
  PROJECT
  ROADMAP
  TECHSTACK
}

enum NodeStatus {
  DRAFT
  PUBLISHED
}

model RoadmapNode {
  id        String @id @default(uuid())
  roadmapId String @map("roadmap_id")

  // content
  title              String
  slug               String
  description        String?
  type               NodeType   @default(TECHSTACK)
  status             NodeStatus @default(DRAFT)
  parentId           String?    @map("parent_id")
  referenceRoadmapId String?    @map("reference_roadmap_id")
  order              Int        @default(0)

  // timestamps
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // relationships
  roadmap          Roadmap       @relation("RoadmapNodes", fields: [roadmapId], references: [id], onDelete: Cascade)
  parent           RoadmapNode?  @relation("NodeChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children         RoadmapNode[] @relation("NodeChildren")
  referenceRoadmap Roadmap?      @relation("RoadmapReferences", fields: [referenceRoadmapId], references: [id], onDelete: SetNull)

  topicId String? @map("topic_id")
  topic   Topic?  @relation("NodeToTopic", fields: [topicId], references: [id])

  tags            TagsOnNodes[]  @relation("NodeTags")
  progressEntries UserProgress[] @relation("RoadmapNodeProgress")

  @@index([roadmapId, type, status, order])
  @@index([parentId])
  @@index([referenceRoadmapId])
  @@map("roadmap_nodes")
}
