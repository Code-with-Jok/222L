{
  "name": "roadmap-app",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:create": "npx create-db",
    "db:generate": "pnpm --filter @repo/db run db:generate",
    "db:migrate": "pnpm --filter @repo/db run db:migrate",
    "db:push": "pnpm --filter @repo/db run db:push",
    "db:studio": "pnpm --filter @repo/db run db:studio",
    "db:format": "pnpm --filter @repo/db run db:format",
    "db:deploy": "pnpm --filter @repo/db run db:deploy",
    "db:seed": "pnpm --filter @repo/db run db:seed"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "prettier": "^3.7.4",
    "tailwindcss": "^4",
    "turbo": "^2.9.3",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
