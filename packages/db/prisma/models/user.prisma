enum Role {
  USER
  ADMIN
}

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String  @map("password_hash")
  role         Role    @default(USER)
  name         String?
  displayName  String? @map("display_name")
  avatarUrl    String? @map("avatar_url")
  isActive     Boolean @default(true) @map("is_active")

  // security
  emailVerifiedAt DateTime? @map("email_verified_at")
  // failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  // lockedUntil         DateTime? @map("locked_until")

  // timestamps
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // relationships
  sessions          Session[]        @relation("UserSessions")
  authTokens        AuthToken[]      @relation("UserAuthTokens")
  bookmarks         Bookmark[]       @relation("UserBookmarks")
  progressEntries   UserProgress[]   @relation("UserProgress")
  ownedRoadmaps     Roadmap[]        @relation("RoadmapOwner")
  authoredRoadmaps  Roadmap[]        @relation("RoadmapAuthor")
  createdVersions   RoadmapVersion[] @relation("RoadmapVersionCreatedBy")
  publishedVersions RoadmapVersion[] @relation("RoadmapVersionPublishedBy")

  @@map("users")
}

model Session {
  id     String @id @default(uuid())
  userId String @map("user_id")

  // token info
  expiresAt           DateTime @map("expires_at")
  tokenHash           String?  @map("token_hash")
  refreshFamilyId     String?  @map("refresh_family_id")
  replacedBySessionId String?  @unique @map("replaced_by_session_id")

  // revoke info
  revokedAt    DateTime? @map("revoked_at")
  revokeReason String?   @map("revoke_reason")

  // device info
  userAgent  String?   @map("user_agent")
  ipAddress  String?   @map("ip_address")
  lastSeenAt DateTime? @map("last_seen_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // relationships
  user              User        @relation("UserSessions", fields: [userId], references: [id], onDelete: Cascade)
  replacedBySession Session?    @relation("SessionRotation", fields: [replacedBySessionId], references: [id], onDelete: SetNull)
  previousSession   Session?    @relation("SessionRotation")
  authTokens        AuthToken[] @relation("SessionAuthTokens")

  @@index([userId, revokedAt, expiresAt])
  @@map("sessions")
}

enum AuthTokenPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model AuthToken {
  id     String @id @default(uuid())
  userId String @map("user_id")

  // token info
  sessionId String? @map("session_id")
  tokenHash String  @unique @map("token_hash")

  // purpose
  purpose AuthTokenPurpose

  consumedAt DateTime? @map("consumed_at")
  // expiry
  expiresAt  DateTime  @map("expires_at")

  // timestamps
  createdAt DateTime @default(now()) @map("created_at")

  user    User     @relation("UserAuthTokens", fields: [userId], references: [id], onDelete: Cascade)
  session Session? @relation("SessionAuthTokens", fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, consumedAt, expiresAt])
  @@map("auth_tokens")
}

model Bookmark {
  id     String @id @default(uuid())
  userId String @map("user_id")

  roadmapId String @map("roadmap_id")

  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation("UserBookmarks", fields: [userId], references: [id], onDelete: Cascade)
  roadmap Roadmap @relation("RoadmapBookmarks", fields: [roadmapId], references: [id], onDelete: Cascade)

  @@unique([userId, roadmapId])
  @@index([roadmapId, createdAt])
  @@map("bookmarks")
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

model UserProgress {
  id     String @id @default(uuid())
  userId String @map("user_id")

  // roadmap
  roadmapId     String         @map("roadmap_id")
  roadmapNodeId String         @map("roadmap_node_id")
  status        ProgressStatus @default(NOT_STARTED)
  completedAt   DateTime?      @map("completed_at")
  lastVisitedAt DateTime?      @map("last_visited_at")

  // timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // relationships
  user        User        @relation("UserProgress", fields: [userId], references: [id], onDelete: Cascade)
  roadmap     Roadmap     @relation("RoadmapProgress", fields: [roadmapId], references: [id], onDelete: Cascade)
  roadmapNode RoadmapNode @relation("RoadmapNodeProgress", fields: [roadmapNodeId], references: [id], onDelete: Cascade)

  @@unique([userId, roadmapNodeId])
  @@index([userId, roadmapId, status, createdAt])
  @@map("user_progress")
}
