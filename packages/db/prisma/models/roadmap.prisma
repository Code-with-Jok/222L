enum RoadmapStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum RoadmapVisibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

enum RoadmapVersionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Roadmap{
  id          String        @id @default(uuid())
  title       String
  slug        String        @unique
  description String?
  status      RoadmapStatus @default(DRAFT)
  visibility  RoadmapVisibility @default(PUBLIC)
  currentVersionId String?  @unique @map("current_version_id")
  
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  authorId           String             @map("author_id")
  ownerId            String             @map("owner_id")
  author             User               @relation(fields: [authorId], references: [id])
  owner              User               @relation("RoadmapOwner", fields: [ownerId], references: [id])
  currentVersion     RoadmapVersion?    @relation("RoadmapCurrentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  versions           RoadmapVersion[]   @relation("RoadmapVersions")
  nodes              RoadmapNode[]      @relation("RoadmapToNodes")
  referencedRoadmaps RoadmapNode[]      @relation("NodeToReferencedRoadmap")
  tags               TagsOnRoadmaps[]   @relation("RoadmapTags") 
  bookmarks          Bookmark[]
  progressEntries    UserProgress[]

  // Indexes
  @@index([slug, status, deletedAt])
  @@index([status, deletedAt])
  @@index([ownerId, status, deletedAt])
  @@map("roadmap")
}

model RoadmapVersion{
  id            String  @id @default(uuid())
  roadmapId     String  @map("roadmap_id")
  versionNumber Int     @map("version_number")
  snapshotData  Json
  title         String
  description   String?
  status        RoadmapVersionStatus @default(DRAFT)
  changelog     String?
  createdById   String  @map("created_by_id")
  publishedById String? @map("published_by_id")
  publishedAt   DateTime? @map("published_at")


  createdAt     DateTime @default(now()) @map("created_at")
  
  // N - 1 relationship
  roadmap       Roadmap @relation("RoadmapVersions", fields: [roadmapId], references: [id], onDelete: Cascade)
  activeForRoadmap Roadmap? @relation("RoadmapCurrentVersion")
  createdBy     User    @relation("RoadmapVersionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  publishedBy   User?   @relation("RoadmapVersionPublishedBy", fields: [publishedById], references: [id], onDelete: SetNull)
  
  // Indexes
  @@unique([roadmapId, versionNumber])
  @@index([roadmapId, status, createdAt])
  @@map("roadmap_versions")
}

enum NodeType {
  PRACTICE
  PROJECT
  ROADMAP 
  TECHSTACK 
}

enum NodeStatus {
  DRAFT
  PUBLISHED
}

model RoadmapNode{
  id                  String  @id @default(uuid())
  roadmapId           String  @map("roadmap_id")
  title               String 
  slug                String
  description         String?
  type                NodeType   @default(TECHSTACK)
  status              NodeStatus @default(DRAFT)
  parentId            String?    @map("parent_id")
  referenceRoadmapId  String?    @map("reference_roadmap_id")
  order               Int        @default(0)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  
  // N - 1 relationship
  roadmap           Roadmap           @relation("RoadmapToNodes", fields: [roadmapId], references: [id], onDelete: Cascade)
  parent            RoadmapNode?      @relation("NodeToNode", fields: [parentId], references: [id])
  children          RoadmapNode[]     @relation("NodeToNode")
  referencedRoadmap Roadmap?          @relation("NodeToReferencedRoadmap", fields: [referenceRoadmapId], references: [id])
  
  topicId           String? @map("topic_id")
  topic             Topic?            @relation("NodeToTopic", fields: [topicId], references: [id])

  tags  TagsOnNodes[] @relation("NodeTags")
  progressEntries UserProgress[]

  // Indexes
  @@unique([roadmapId, slug])
  @@index([roadmapId, parentId, order])
  @@map("roadmap_nodes")
}
